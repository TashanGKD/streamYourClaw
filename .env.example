# Application
APP_NAME=streamYourClaw
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_PREFIX=syc

# Frontend
FRONTEND_PATH=frontend

# Agent settings
SUPERVISOR_MODEL=gpt-4
OPENCLAW_ADAPTER=mock

# LLM settings (for Supervisor Agent)
# Uncomment and fill in your API key for real LLM usage
# LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=https://api.openai.com/v1